# ====== Copia este archivo a .env y ajusta valores ======

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=renova
POSTGRES_PASSWORD=renova123
POSTGRES_DB=renova

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=renova

# --- Redis (cola async / rate-limit) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Seguridad ---
JWT_SECRET=cambia-esta-clave-super-secreta-en-produccion
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Puertos de servicios (dev local) ---
GATEWAY_PORT=4000
AUTH_PORT=3001
PACIENTES_PORT=3002
CITAS_PORT=3003
HOSPITALIZACION_PORT=3004
FARMACIA_PORT=3005
LABORATORIO_PORT=3006
FACTURACION_PORT=3007
NOTIFICACIONES_PORT=3008
REPORTES_PORT=3009

# --- URLs internas (usadas por el Gateway) ---
AUTH_URL=http://localhost:3001
PACIENTES_URL=http://localhost:3002
CITAS_URL=http://localhost:3003
HOSPITALIZACION_URL=http://localhost:3004
FARMACIA_URL=http://localhost:3005
LABORATORIO_URL=http://localhost:3006
FACTURACION_URL=http://localhost:3007
NOTIFICACIONES_URL=http://localhost:3008
REPORTES_URL=http://localhost:3009

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:4000
